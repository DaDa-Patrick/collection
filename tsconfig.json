{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "preserve",
    "jsxImportSource": "astro",
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
