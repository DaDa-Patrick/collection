---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import { getProjectAccent } from '../../utils/project-accent.ts';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { data } = project;

const accentRaw = typeof data.accent === "string" ? data.accent.trim() : "";
const accentFallback = accentRaw.length > 0 ? accentRaw : "#6f7bff";
const accentValue = data.image ? await getProjectAccent(project.filePath, accentFallback) : accentFallback;
const style = `--accent: ${accentValue};`;
const sidebar = data.sidebar ?? {};
const role = data.role ?? sidebar.role;
const period = data.period ?? sidebar.period;
const type = data.type ?? sidebar.type;
const techStack = data.techStack ?? sidebar.techStack;
const deliverables = data.deliverables ?? sidebar.deliverables;

const targetLandscape = 16 / 9;
const targetPortrait = 9 / 16;
const aspectTolerance = 0.12;
const imageRatio = data.image ? data.image.width / data.image.height : null;
const isPortrait = imageRatio !== null ? imageRatio < 1 : false;
const isNear = (ratio: number, target: number) => Math.abs(ratio - target) / target <= aspectTolerance;
const heroAspect = imageRatio
  ? isPortrait
    ? (isNear(imageRatio, targetPortrait) ? imageRatio : targetPortrait)
    : (isNear(imageRatio, targetLandscape) ? imageRatio : targetLandscape)
  : targetLandscape;
const heroAspectValue = heroAspect.toFixed(6);
const galleryItems = [
  ...(data.image ? [{
    image: data.image,
    full: data.image.src,
    alt: `${data.title} 主視覺`,
  }] : []),
  ...((data.gallery ?? []).map((img, index) => ({
    image: typeof img === 'string' ? img : img,
    full: typeof img === 'string' ? img : img.src,
    alt: `${data.title} showcase ${index + 1}`,
  }))),
];
const hasLightbox = galleryItems.length > 0;

// Navigation Logic
const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.date.localeCompare(a.data.date));
const currentIndex = sortedProjects.findIndex(p => p.id === project.id);

const prevProject = currentIndex > 0 ? sortedProjects[currentIndex - 1] : sortedProjects[sortedProjects.length - 1];
const nextProject = currentIndex < sortedProjects.length - 1 ? sortedProjects[currentIndex + 1] : sortedProjects[0];

// Get 3 random or next projects for the "More Works" section
const moreProjects = sortedProjects.filter(p => p.id !== project.id).slice(0, 3);

// Helper for link icons
const getLinkIcon = (label: string) => {
  const l = label.toLowerCase();
  if (l.includes('github') || l.includes('code') || l.includes('repo')) return '🐙';
  if (l.includes('demo') || l.includes('live') || l.includes('web') || l.includes('site')) return '🚀';
  if (l.includes('figma') || l.includes('design') || l.includes('spec')) return '🎨';
  if (l.includes('download') || l.includes('app') || l.includes('play')) return '📱';
  return '🔗';
};
---

<MainLayout title={`${data.title} | Patrick Huang`} description={data.description}>
  <main class="project-page" style={style}>
    <section
      class="section project-hero"
      aria-labelledby="project-title"
    >
      {data.image && (
        <div class="project-hero__bg">
          <div class="project-hero__bg-blur" style={`background-image: url(${data.image.src})`}></div>
          <div class="project-hero__bg-overlay"></div>
        </div>
      )}
      <div class="container project-hero__container">
        <nav class="project-breadcrumb" aria-label="Breadcrumb" data-project-enter style="--enter-step: 0;">
          <a href="/#projects" class="breadcrumb-link">
            <span class="icon-arrow">←</span> 返回專案列表
          </a>
        </nav>
        
        <div class="project-hero__layout">
          <div class="project-hero__info">
            <div class="project-hero__badge" data-project-enter style="--enter-step: 1;">{data.tagLabel}</div>
            <h1 class="project-hero__title" id="project-title" data-project-enter style="--enter-step: 2;">{data.title}</h1>
            <p class="project-hero__meta" data-project-enter style="--enter-step: 3;">{data.meta}</p>
            <p class="project-hero__description" data-project-enter style="--enter-step: 4;">
              {data.description}
            </p>
            
            {data.links && data.links.length > 0 && (
              <div class="project-links" data-project-enter style="--enter-step: 5;">
                {data.links.map(link => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer" class="btn-link">
                    <span class="btn-link__label">{link.label}</span>
                  </a>
                ))}
              </div>
            )}

            <div class="project-hero__tags" data-project-enter style="--enter-step: 6;">
              {data.tags.map(t => <span class="tag">#{t}</span>)}
            </div>
          </div>

          <div class="project-hero__visual">
            {data.image ? (
              <button
                type="button"
                class={`project-hero__image-main${isPortrait ? " is-portrait" : ""}`}
                style={`--hero-aspect: ${heroAspectValue}; --enter-step: 7;`}
                data-project-enter
                data-gallery-index="0"
                data-gallery-full={galleryItems[0].full}
                data-gallery-alt={galleryItems[0].alt}
                aria-label={`查看大圖：${galleryItems[0].alt}`}
              >
                <Image 
                  src={data.image} 
                  alt={data.title} 
                  width={1200} 
                  class="project-hero__img" 
                  loading="eager"
                />
              </button>
            ) : (
              <div
                class={`project-hero__image-main${isPortrait ? " is-portrait" : ""}`}
                style={`--hero-aspect: ${heroAspectValue}; --enter-step: 7;`}
                data-project-enter
              >
                <div class="project-hero__placeholder" />
              </div>
            )}
            
            {data.gallery && data.gallery.length > 0 && (
              <div class="project-hero__gallery" data-project-enter style="--enter-step: 8;">
                {galleryItems.slice(data.image ? 1 : 0).map((item, index) => (
                  <button
                    type="button"
                    class="gallery-item"
                    data-gallery-index={(data.image ? 1 : 0) + index}
                    data-gallery-full={item.full}
                    data-gallery-alt={item.alt}
                    aria-label={`查看大圖：${item.alt}`}
                  >
                    <Image 
                      src={item.image} 
                      alt={item.alt} 
                      width={800} 
                      class="gallery-img" 
                      loading="eager"
                      decoding="sync"
                    />
                  </button>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="section project-content">
      <div class="container project-content__grid">
        <div class="project-content__body" data-project-enter style="--enter-step: 9;">
          {data.highlights && data.highlights.length > 0 && (
            <div class="project-highlight-box" style="margin-top: 0; margin-bottom: 40px;">
              <h2>專案亮點</h2>
              <ul class="highlight-list">
                {data.highlights.map(h => <li>{h}</li>)}
              </ul>
            </div>
          )}

          <div class="prose">
            <Content />
          </div>
        </div>

        <aside class="project-specs" aria-label="詳細參數" data-project-enter style="--enter-step: 10;">
          {(role || period || type) && (
            <div class="spec-card">
              <div class="spec-card__header">
                <h3>專案規格</h3>
              </div>
              <div class="spec-list">
                {role && (
                  <div class="spec-item">
                    <span class="label">我的角色</span>
                    <span class="value">{role}</span>
                  </div>
                )}
                {period && (
                  <div class="spec-item">
                    <span class="label">專案期間</span>
                    <span class="value">{period}</span>
                  </div>
                )}
                {type && (
                  <div class="spec-item">
                    <span class="label">開發型態</span>
                    <span class="value">{type}</span>
                  </div>
                )}
              </div>
            </div>
          )}
          
          {techStack && techStack.length > 0 && (
            <div class="spec-card">
              <div class="spec-card__header">
                <h3>技術堆疊</h3>
              </div>
              <div class="tech-tags">{techStack.map(t => <span class="tech-tag">{t}</span>)}</div>
            </div>
          )}

          {deliverables && deliverables.length > 0 && (
            <div class="spec-card">
              <div class="spec-card__header">
                <span class="spec-icon">📦</span>
                <h3>交付成果</h3>
              </div>
              <ul class="deliver-list">
                {deliverables.map(d => <li>{d}</li>)}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </section>

    <nav class="project-navigation" aria-label="專案步進" data-project-enter style="--enter-step: 11;">
      <div class="container project-navigation__wrapper">
        <div class="project-navigation__inner">
          <a href={`/projects/${prevProject.id}`} class="nav-card nav-card--prev">
            <div class="nav-card__bg">
               {prevProject.data.image && <Image src={prevProject.data.image} alt="" width={800} class="nav-card__bg-img" />}
            </div>
            <div class="nav-card__content">
              <span class="nav-card__tag">PREVIOUS</span>
              <h4 class="nav-card__name">{prevProject.data.title}</h4>
            </div>
            <div class="nav-card__icon">←</div>
          </a>
          
          <a href={`/projects/${nextProject.id}`} class="nav-card nav-card--next">
            <div class="nav-card__bg">
               {nextProject.data.image && <Image src={nextProject.data.image} alt="" width={800} class="nav-card__bg-img" />}
            </div>
            <div class="nav-card__content">
              <span class="nav-card__tag">NEXT PROJECT</span>
              <h4 class="nav-card__name">{nextProject.data.title}</h4>
              <p class="nav-card__desc">{nextProject.data.tagLabel}</p>
            </div>
            <div class="nav-card__action">
              <span>立即閱讀</span>
              <div class="circle-btn">→</div>
            </div>
          </a>
        </div>
      </div>
    </nav>

    <section class="section more-works" data-project-enter style="--enter-step: 12;">
      <div class="container">
        <div class="more-works__top">
          <div class="more-works__title-area">
             <span class="eyebrow">GALLERY</span>
             <h2>探索更多作品</h2>
          </div>
          <a href="/#projects" class="btn-all">全部作品覽覽 <span class="arrow">↗</span></a>
        </div>
        <div class="more-works__cards">
          {moreProjects.map((p, index) => (
            <a href={`/projects/${p.id}`} class="work-card" data-project-enter style={`--enter-step: ${13 + index};`}>
              <div class="work-card__media">
                {p.data.image && <Image src={p.data.image} alt="" width={500} />}
                <div class="work-card__overlay">
                   <span>VIEW CASE</span>
                </div>
              </div>
              <div class="work-card__details">
                <span class="work-card__label">{p.data.tagLabel}</span>
                <h3>{p.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section project-footer">
      <div class="container" data-project-enter style="--enter-step: 16;">
        <div class="footer-card">
          <div class="footer-card__glow"></div>
          <h2>想了解更多細節？</h2>
          <p>我很樂意分享這項專案的技術細節與設計思維。隨時歡迎交流！</p>
          <div class="footer-actions">
            <a href="mailto:dada.patrick@gmail.com" class="btn btn--primary">聯繫我</a>
            <a href="/#projects" class="btn btn--white">查看更多作品</a>
          </div>
        </div>
      </div>
    </section>

    {hasLightbox && (
      <dialog class="gallery-lightbox" data-gallery-lightbox data-gallery-count={galleryItems.length} aria-label={`${data.title} 圖片預覽`}>
        <div class="gallery-lightbox__shell">
          <button type="button" class="gallery-lightbox__close" data-gallery-close aria-label="關閉圖片預覽">×</button>
          <div class="gallery-lightbox__stage">
            <button type="button" class="gallery-lightbox__nav" data-gallery-prev aria-label="上一張">←</button>
            <img class="gallery-lightbox__image" data-gallery-image alt="" />
            <button type="button" class="gallery-lightbox__nav" data-gallery-next aria-label="下一張">→</button>
          </div>
          <div class="gallery-lightbox__meta">
            <span class="gallery-lightbox__counter" data-gallery-counter></span>
            <p class="gallery-lightbox__caption" data-gallery-caption></p>
          </div>
        </div>
      </dialog>
    )}
  </main>
</MainLayout>

<script>
  let cleanupProjectGallery = () => {};

  const initProjectGallery = () => {
    cleanupProjectGallery();

    const dialog = document.querySelector("[data-gallery-lightbox]");
    const triggers = Array.from(document.querySelectorAll("[data-gallery-index]"));

    if (!(dialog instanceof HTMLDialogElement) || triggers.length === 0) {
      cleanupProjectGallery = () => {};
      return;
    }

    const image = dialog.querySelector("[data-gallery-image]");
    const caption = dialog.querySelector("[data-gallery-caption]");
    const counter = dialog.querySelector("[data-gallery-counter]");
    const closeButton = dialog.querySelector("[data-gallery-close]");
    const prevButton = dialog.querySelector("[data-gallery-prev]");
    const nextButton = dialog.querySelector("[data-gallery-next]");
    const stage = dialog.querySelector(".gallery-lightbox__stage");

    if (!(image instanceof HTMLImageElement) || !(caption instanceof HTMLElement) || !(counter instanceof HTMLElement)) {
      return;
    }

    let activeIndex = 0;
    let touchStartX = 0;
    let touchStartY = 0;
    let touchMoved = false;
    let openAnimationFrame = 0;
    const disposers: Array<() => void> = [];

    const renderSlide = (index: number) => {
      const safeIndex = (index + triggers.length) % triggers.length;
      const trigger = triggers[safeIndex];
      const full = trigger.getAttribute("data-gallery-full") || "";
      const alt = trigger.getAttribute("data-gallery-alt") || "";

      activeIndex = safeIndex;
      image.src = full;
      image.alt = alt;
      caption.textContent = alt;
      counter.textContent = `${safeIndex + 1} / ${triggers.length}`;
    };

    const openLightbox = (index: number) => {
      renderSlide(index);
      if (!dialog.open) {
        dialog.dataset.state = "opening";
        dialog.showModal();
        cancelAnimationFrame(openAnimationFrame);
        openAnimationFrame = requestAnimationFrame(() => {
          dialog.dataset.state = "open";
        });
      }
    };

    triggers.forEach((trigger, index) => {
      const handleTriggerClick = () => openLightbox(index);
      trigger.addEventListener("click", handleTriggerClick);
      disposers.push(() => trigger.removeEventListener("click", handleTriggerClick));
    });

    const handlePrev = () => renderSlide(activeIndex - 1);
    const handleNext = () => renderSlide(activeIndex + 1);
    const handleCloseButton = () => dialog.close();

    prevButton?.addEventListener("click", handlePrev);
    nextButton?.addEventListener("click", handleNext);
    closeButton?.addEventListener("click", handleCloseButton);
    if (prevButton) disposers.push(() => prevButton.removeEventListener("click", handlePrev));
    if (nextButton) disposers.push(() => nextButton.removeEventListener("click", handleNext));
    if (closeButton) disposers.push(() => closeButton.removeEventListener("click", handleCloseButton));

    const handleDialogClick = (event: MouseEvent) => {
      if (event.target === dialog) {
        dialog.close();
      }
    };

    const handleDialogClose = () => {
      dialog.dataset.state = "closed";
      cancelAnimationFrame(openAnimationFrame);
      image.removeAttribute("src");
      image.alt = "";
    };

    const handleKeydown = (event: KeyboardEvent) => {
      if (!dialog.open) return;
      if (event.key === "ArrowLeft") renderSlide(activeIndex - 1);
      if (event.key === "ArrowRight") renderSlide(activeIndex + 1);
    };

    dialog.addEventListener("click", handleDialogClick);
    dialog.addEventListener("close", handleDialogClose);
    window.addEventListener("keydown", handleKeydown);
    disposers.push(() => dialog.removeEventListener("click", handleDialogClick));
    disposers.push(() => dialog.removeEventListener("close", handleDialogClose));
    disposers.push(() => window.removeEventListener("keydown", handleKeydown));

    const handleTouchStart = (event: TouchEvent) => {
      const touch = event.changedTouches[0];
      if (!touch) return;
      touchStartX = touch.clientX;
      touchStartY = touch.clientY;
      touchMoved = true;
    };

    const handleTouchEnd = (event: TouchEvent) => {
      if (!touchMoved) return;

      const touch = event.changedTouches[0];
      if (!touch) return;

      const deltaX = touch.clientX - touchStartX;
      const deltaY = touch.clientY - touchStartY;
      const absX = Math.abs(deltaX);
      const absY = Math.abs(deltaY);

      touchMoved = false;

      if (absX < 48 || absX <= absY) return;

      if (deltaX > 0) {
        renderSlide(activeIndex - 1);
      } else {
        renderSlide(activeIndex + 1);
      }
    };

    stage?.addEventListener("touchstart", (e) => handleTouchStart(e as TouchEvent), { passive: true });
    stage?.addEventListener("touchend", (e) => handleTouchEnd(e as TouchEvent), { passive: true });
    if (stage) {
      disposers.push(() => stage.removeEventListener("touchstart", (e) => handleTouchStart(e as TouchEvent)));
      disposers.push(() => stage.removeEventListener("touchend", (e) => handleTouchEnd(e as TouchEvent)));
    }

    cleanupProjectGallery = () => {
      cancelAnimationFrame(openAnimationFrame);
      if (dialog.open) dialog.close();
      disposers.forEach((dispose) => dispose());
    };
  };

  document.addEventListener("DOMContentLoaded", initProjectGallery, { once: true });
  document.addEventListener("astro:page-load", initProjectGallery);
</script>

<style>
  .project-page {
    /* 
       THE READY-MADE ALGORITHM: 
       1. Calculate a theme-aware "safe" accent that doesn't wash out in Light Mode 
          or disappear in Dark Mode.
    */
    --accent-safe: oklch(from var(--accent) clamp(0.35, l, 0.45) c h);

    /* 
       THE CONTRAST FORMULA:
       Switch text between Black/White based on the background (accent-safe) lightness.
       If L > 0.45 -> Black, else White.
    */
    --accent-fg: oklch(from var(--accent-safe) calc((l - 0.45) * -100) 0 0);

    --accent-soft: color-mix(in srgb, var(--accent-safe), transparent 85%);
    --accent-glow: color-mix(in srgb, var(--accent-safe), transparent 60%);
  }

  @keyframes project-enter-rise {
    from {
      opacity: 0;
      transform: translate3d(0, 22px, 0) scale(0.985);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  .project-page [data-project-enter] {
    opacity: 0;
    transform: translate3d(0, 22px, 0) scale(0.985);
    animation-name: project-enter-rise;
    animation-duration: 620ms;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: forwards;
    animation-delay: calc(90ms + (var(--enter-step, 0) * 72ms));
    will-change: opacity, transform;
  }

  :global(.theme-dark) .project-page {
    --accent-safe: oklch(from var(--accent) clamp(0.75, l, 0.95) c h);
  }

  .project-hero {
    position: relative;
    padding-top: 140px;
    padding-bottom: 80px;
    background: var(--color-bg);
    overflow: hidden;
    isolation: isolate;
  }

  :root:not(.theme-dark) .project-hero {
    background: #fff;
  }

  .project-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .project-hero__bg-blur {
    position: absolute;
    inset: -8%;
    background-size: cover;
    background-position: center;
    filter: blur(40px) saturate(1.2);
    opacity: 0.45;
  }

  :root:not(.theme-dark) .project-hero__bg-blur {
    opacity: 0.25;
    filter: blur(60px) saturate(1.1);
  }

  .project-hero__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom, 
      color-mix(in srgb, var(--color-bg), transparent 75%), 
      var(--color-bg) 98%
    );
    backdrop-filter: none;
  }

  :root:not(.theme-dark) .project-hero__bg-overlay {
    background: linear-gradient(
      to bottom, 
      rgba(255, 255, 255, 0.4), 
      #ffffff 98%
    );
  }

  .project-hero__container {
    position: relative;
    z-index: 1;
  }

  .project-breadcrumb {
    margin-bottom: 40px;
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s var(--transition);
    padding: 10px 20px;
    background: color-mix(in srgb, var(--color-surface-strong), transparent 20%);
    border-radius: 100px;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
  }

  .breadcrumb-link:hover {
    color: var(--color-primary);
    transform: translateX(-4px);
    box-shadow: var(--shadow-hover);
  }

  .project-hero__layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .project-hero__layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  /* Text Section */
  .project-hero__info {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .project-hero__badge {
    display: inline-block;
    padding: 6px 12px;
    background: var(--accent-soft);
    color: var(--accent-safe);
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    width: fit-content;
    border: 1px solid var(--accent-glow);
  }

  .project-hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    font-weight: 800;
    margin: 0;
    text-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .project-hero__meta {
    font-size: 1.25rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .project-hero__description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text-main);
    max-width: 500px;
  }

  .project-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
  }

  .tag {
    font-size: 0.9rem;
    color: var(--accent-safe);
    opacity: 0.8;
    font-weight: 500;
  }

  /* Link Buttons */
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 10px;
    margin-bottom: 5px;
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    background: var(--accent-safe);
    color: var(--accent-fg) !important;
    text-decoration: none !important;
    border-radius: 14px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 8px 20px var(--accent-glow);
    border: 1px solid rgba(0,0,0,0.1);
  }

  :global(.theme-light) .btn-link {
    color: #fff !important;
