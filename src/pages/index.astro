---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Intro from '../components/Intro.astro';
import About from '../components/About.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Contact from '../components/Contact.astro';

const allProjects = await getCollection('projects');
// Sort projects by date descending (assuming format like "2024.03")
const sortedProjects = allProjects.sort((a, b) => b.data.date.localeCompare(a.data.date));

const filters = [
	{ id: 'all', label: '全部' },
	{ id: 'ai', label: 'AI / 自動化' },
	{ id: 'web', label: 'Web / 前端' },
	{ id: 'mobile', label: '行動應用' },
	{ id: 'hardware', label: '硬體 / IoT' },
	{ id: 'game', label: '遊戲' },
	{ id: 'data', label: '資料平台' },
];
---

<MainLayout>
	<main data-scroll-root>
		<Intro />
		<About />

		<section
			class="section section--layered"
			id="projects"
			aria-labelledby="project-heading"
			data-snap-section
		>
			<div class="container">
				<span class="section__float section__float--projects" aria-hidden="true" data-parallax-depth="0.05"></span>
				<div class="section__header">
					<p class="section__eyebrow">PORTFOLIO</p>
					<h2 class="section__title" id="project-heading">代表專案</h2>
					<p class="section__subtitle">
						精選 {sortedProjects.length} 個橫跨 AI、行動應用、資料平台、互動遊戲與硬體裝置的作品。
						透過下方篩選快速找到你感興趣的領域。
					</p>
				</div>

				<div class="filter-controls" role="toolbar" aria-label="專案篩選">
					{filters.map((f) => (
						<button 
							class={`filter-btn ${f.id === 'all' ? 'is-active' : ''}`} 
							type="button" 
							data-filter={f.id}
						>
							{f.label}
						</button>
					))}
				</div>

				<div class="project-timeline" data-animate-group data-animate-interval="140">
					{sortedProjects.map((project) => (
						<ProjectCard 
							id={project.id}
							filePath={project.filePath}
							{...project.data}
						/>
					))}
				</div>
			</div>
		</section>

		<Contact />
	</main>
</MainLayout>

<script>
	let cleanupProjectFilters = () => {};

	const initProjectFilters = () => {
		cleanupProjectFilters();

		const filterButtons = Array.from(document.querySelectorAll(".filter-btn")) as HTMLElement[];
		const projectCards = Array.from(document.querySelectorAll(".project-card")) as HTMLElement[];

		if (!filterButtons.length || !projectCards.length) {
			cleanupProjectFilters = () => {};
			return;
		}

		const disposers: Array<() => void> = [];
		let refreshTimers: number[] = [];

		const clearRefreshState = () => {
			refreshTimers.forEach((timer) => window.clearTimeout(timer));
			refreshTimers = [];
			projectCards.forEach((card) => {
				card.classList.remove("is-filter-refreshing");
				card.style.removeProperty("--filter-refresh-delay");
			});
		};

		function filterProjects(tag: string) {
			const visibleCards: HTMLElement[] = [];
			const viewportHeight = window.innerHeight || 1;
			clearRefreshState();

			projectCards.forEach((card) => {
				const tags = (card.dataset.tags || "").split(/\s+/).filter(Boolean);
				const shouldShow = tag === "all" || tags.includes(tag);
				card.dataset.hidden = shouldShow ? "false" : "true";

				if (shouldShow) {
					card.style.display = "";
					const rect = card.getBoundingClientRect();
					const isInViewport = rect.top < viewportHeight * 0.92 && rect.bottom > 0;

					if (isInViewport) {
						card.classList.add("is-visible");
						visibleCards.push(card);
					} else {
						card.classList.remove("is-visible");
					}
				} else {
					card.style.display = "none";
					card.classList.remove("is-visible");
				}
			});

			void document.body.offsetWidth;

			visibleCards.forEach((card, index) => {
				card.style.setProperty("--filter-refresh-delay", `${index * 90}ms`);
				card.classList.add("is-filter-refreshing");
				refreshTimers.push(window.setTimeout(() => {
					card.classList.remove("is-filter-refreshing");
					card.style.removeProperty("--filter-refresh-delay");
				}, 780 + index * 90));
			});
		}

		filterButtons.forEach((btn) => {
			const handleClick = () => {
				filterButtons.forEach((b) => b.classList.remove("is-active"));
				btn.classList.add("is-active");
				const filter = btn.dataset.filter || "all";
				filterProjects(filter);
			};

			btn.addEventListener("click", handleClick);
			disposers.push(() => btn.removeEventListener("click", handleClick));
		});

		cleanupProjectFilters = () => {
			clearRefreshState();
			disposers.forEach((dispose) => dispose());
		};
	};

	document.addEventListener("DOMContentLoaded", initProjectFilters, { once: true });
	document.addEventListener("astro:page-load", initProjectFilters);
</script>
