---
import { Image } from "astro:assets";
import profileImage from "../assets/projects/IMG_3300.jpeg";
---

<section
    class="section section--intro"
    id="intro"
    aria-labelledby="intro-heading"
    data-snap-section
>
    <div class="container intro" data-animate-group data-animate-interval="140">
        <div
            class="intro__media"
            data-parallax-depth="0.08"
            data-animate="fade"
        >
            <span class="intro__glow" aria-hidden="true"></span>
            <div class="intro__badge" aria-hidden="true">
                <Image 
                    src={profileImage} 
                    alt="Patrick's profile photo" 
                    class="intro__profile-img"
                    loading="eager"
                />
                <span class="intro__badge-caption">Product & AI Engineer</span>
            </div>
        </div>
        <div class="intro__content" data-animate="fade-up">
            <p class="intro__eyebrow">嗨！我是 Patrick</p>
            <h1 class="intro__title" id="intro-heading">
                <span class="sr-only"
                    >黃子耘，以資工、設計、AI 與更多跨域專長串出驚喜</span
                >
                <span class="intro__title-visual" aria-hidden="true">
                    <span class="intro__title-name">黃子耘</span>
                    <span class="intro__title-line">
                        <span class="intro__title-text">以</span>
                        <span class="intro__title-rotator" data-rotate="leftA"
                            >資工</span
                        >
                        <span class="intro__title-text">、</span>
                        <span class="intro__title-rotator" data-rotate="leftB"
                            >設計</span
                        >
                        <span class="intro__title-text">與</span>
                        <span class="intro__title-rotator" data-rotate="right"
                            >人工智慧</span
                        >
                        <span class="intro__title-text">串出驚喜</span>
                    </span>
                </span>
            </h1>
            <p class="intro__description">
                我對於專題研究與程式設計始終抱持高度熱情，自大二起雙主修資訊工程，期許能把地球科學
                的專業洞察與資工能力交織在一起，創造能真正幫助世界的產品體驗。
            </p>
            <ul class="intro__highlights" aria-label="核心亮點">
                <li><span>+6</span> 年橫跨軟硬體的開發經驗</li>
                <li><span>13</span> 個端到端完成的專案與產品 MVP</li>
                <li><span>3</span> 次帶領團隊獲黑客松／競賽獎項</li>
            </ul>
            <div class="intro__actions">
                <a class="btn btn--primary" href="#projects">探索作品</a>
                <a class="btn btn--ghost" href="#contact">與我合作</a>
            </div>
        </div>
    </div>
</section>

<script>
    let cleanupIntroRotator = () => {};

    const initIntroRotator = () => {
        cleanupIntroRotator();

        const introRotatorTargets = {
            leftA: document.querySelector(
                '[data-rotate="leftA"]',
            ) as HTMLElement,
            leftB: document.querySelector(
                '[data-rotate="leftB"]',
            ) as HTMLElement,
            right: document.querySelector(
                '[data-rotate="right"]',
            ) as HTMLElement,
        };

        const introRotatorWords = {
            leftA: ["資工", "軟體", "資料", "演算法"],
            leftB: ["設計", "硬體", "產品", "前端"],
            right: ["人工智慧", "互動", "體驗", "後端"],
        };

        const hasIntroRotator = Object.values(introRotatorTargets).every(
            (el) => el instanceof HTMLElement,
        );
        if (!hasIntroRotator) {
            cleanupIntroRotator = () => {};
            return;
        }

        let currentIndex = 0;
        let rotationTimer = 0;

        function animateSwap(el: HTMLElement, word: string) {
            const exit = el.animate(
                [
                    { opacity: 1, transform: "translateY(0)" },
                    { opacity: 0, transform: "translateY(-15px)" },
                ],
                { duration: 350, easing: "cubic-bezier(0.22, 1, 0.36, 1)" },
            );

            exit.onfinish = () => {
                el.textContent = word;
                el.animate(
                    [
                        { opacity: 0, transform: "translateY(15px)" },
                        { opacity: 1, transform: "translateY(0)" },
                    ],
                    { duration: 350, easing: "cubic-bezier(0.22, 1, 0.36, 1)" },
                );
            };
        }

        rotationTimer = window.setInterval(() => {
            currentIndex = (currentIndex + 1) % introRotatorWords.leftA.length;
            animateSwap(
                introRotatorTargets.leftA,
                introRotatorWords.leftA[currentIndex],
            );
            animateSwap(
                introRotatorTargets.leftB,
                introRotatorWords.leftB[currentIndex],
            );
            animateSwap(
                introRotatorTargets.right,
                introRotatorWords.right[currentIndex],
            );
        }, 3000);

        cleanupIntroRotator = () => {
            window.clearInterval(rotationTimer);
        };
    };

    document.addEventListener("DOMContentLoaded", initIntroRotator, {
        once: true,
    });
    document.addEventListener("astro:page-load", initIntroRotator);
</script>
