---
import { Image } from 'astro:assets';
import { getProjectAccent } from '../utils/project-accent';

interface Props {
	id: string;
	title: string;
	date: string;
	tagLabel: string;
	tags?: string | string[];
	meta: string;
	description: string;
	accent?: string;
	highlights?: string[];
	image?: any; // Optimized image object from Astro
	filePath?: string;
}

const { 
	id, 
	title, 
	date, 
	tagLabel, 
	tags = [], 
	meta, 
	description, 
	accent, 
	highlights = [],
	image,
	filePath
} = Astro.props;

// Handle tags as both string or array
const tagsList = Array.isArray(tags) ? tags.join(' ') : tags;

// CSS Variables for dynamic styling
const accentRaw = typeof accent === "string" ? accent.trim() : "";
const accentFallback = accentRaw.length > 0 ? accentRaw : "#6f7bff";
const accentValue = image ? await getProjectAccent(filePath, accentFallback) : accentFallback;
const style = `--accent: ${accentValue};`;

const targetLandscape = 16 / 9;
const targetPortrait = 9 / 16;
const aspectTolerance = 0.12;
const imageRatio = image ? image.width / image.height : null;
const isPortrait = imageRatio !== null ? imageRatio < 1 : false;
const isNear = (ratio: number, target: number) => Math.abs(ratio - target) / target <= aspectTolerance;
const cardAspect = imageRatio
	? isPortrait
		? (isNear(imageRatio, targetPortrait) ? imageRatio : targetPortrait)
		: (isNear(imageRatio, targetLandscape) ? imageRatio : targetLandscape)
	: targetLandscape;
const cardAspectValue = cardAspect.toFixed(6);

const slug = `/projects/${id}`;
---

<a
	class="project-card"
	data-tags={tagsList}
	id={id}
	href={slug}
	style={style}
	data-animate="tilt"
>
	<span class="project-card__rail" aria-hidden="true"></span>
	<div class="project-card__timeline">
		<time class="project-card__time" datetime={date}>{date}</time>
		<span class="project-card__tag">{tagLabel}</span>
	</div>
	<div class="project-card__body">
		<div class="project-card__content">
			<div class="project-card__header">
				<div class="project-card__heading">
					<h3 class="project-card__title">{title}</h3>
				</div>
				<span class="project-card__meta">{meta}</span>
			</div>
			<p>{description}</p>
			<span class="project-card__cta">查看完整案例</span>
		</div>
		<div class="project-card__media" aria-hidden="true">
			{image ? (
				<>
					<div class="project-card__bg-blur" style={`background-image: url(${image.src})`}></div>
					<div
						class={`project-card__image-frame${isPortrait ? " is-portrait" : ""}`}
						style={`--card-aspect: ${cardAspectValue};`}
					>
						<Image src={image} alt={title} width={600} class="project-card__img" />
					</div>
				</>
			) : (
				<span class="project-card__thumb"></span>
			)}
		</div>
	</div>
</a>

<style>
	.project-card {
		/* 
		   THE READY-MADE ALGORITHM: 
		   Apply same "safe" accent logic as project detail page
		*/
		--accent-safe: oklch(from var(--accent) clamp(0.35, l, 0.45) c h);

		/* THE CONTRAST FORMULA */
		--accent-fg: oklch(from var(--accent-safe) calc((l - 0.45) * -100) 0 0);

		--accent-soft: color-mix(in srgb, var(--accent-safe), transparent 85%);
		--accent-glow: color-mix(in srgb, var(--accent-safe), transparent 60%);
		display: block;
		position: relative;
		padding: 32px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 32px;
		text-decoration: none;
		color: var(--color-text);
		transition: all 0.5s var(--transition);
		overflow: hidden;
	}

	:global(.theme-dark) .project-card {
		--accent-safe: oklch(from var(--accent) clamp(0.75, l, 0.95) c h);
	}

	.project-card:hover {
		transform: translateY(-8px);
		border-color: var(--accent-glow);
		box-shadow: 0 30px 60px -20px rgba(0,0,0,0.5), 0 0 20px var(--accent-soft);
	}

	.project-card__media {
		position: relative;
		overflow: hidden;
		padding: 24px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 20px;
		min-height: 240px;
		background: rgba(0, 0, 0, 0.4);
		border: 1px solid rgba(255, 255, 255, 0.05);
		isolation: isolate; /* Create new stacking context */
	}

	.project-card__bg-blur {
		position: absolute;
		inset: -10%;
		background-size: cover;
		background-position: center;
		filter: blur(20px);
		opacity: 0.55;
		z-index: -1;
		transition: transform 0.6s var(--transition), opacity 0.6s var(--transition);
	}

	.project-card:hover .project-card__bg-blur {
		transform: scale(1.05);
		opacity: 0.75;
	}

	.project-card__image-frame {
		position: relative;
		z-index: 1;
		width: 100%;
		aspect-ratio: var(--card-aspect, 16 / 9);
		border-radius: 16px;
		overflow: hidden;
	}

	.project-card__image-frame.is-portrait {
		max-width: calc(clamp(180px, 22vw, 220px) * var(--card-aspect, 9 / 16));
		margin-inline: auto;
	}

	.project-card__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
		filter: drop-shadow(0 15px 40px rgba(0,0,0,0.6));
	}
	.project-card:hover .project-card__img {
		transform: scale(1.05);
	}

	/* Text and UI Color Synchronization */
	.project-card__time,
	.project-card__tag,
	.project-card__meta,
	.project-card__cta {
		color: var(--accent-safe) !important;
	}

	.project-card__time::before {
		background: var(--accent-safe) !important;
	}

	.project-card__meta {
		opacity: 0.85;
	}

	.project-card__cta {
		font-weight: 700;
		display: flex;
		align-items: center;
		gap: 6px;
	}
</style>
